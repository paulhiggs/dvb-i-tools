			<Definition xml:lang="en">
				Screen reader application supports configurable verbosity</Definition>
		</Term>
		<Term termID="3.4">
			<Name>speed</Name>
			<Definition xml:lang="en">
				Screen reader application supports configurable speech speed/rate</Definition>
      </Term>
