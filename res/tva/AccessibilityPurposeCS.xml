		<Term termID="4.2">
			<Name>visual</Name>
		</Term>
		<Term termID="4.3">
			<Name>haptic</Name>
		</Term>
	</Term>
	<Term termID="5">
		<Name xml:lang="en">Sign language track</Name>
		<Term termID="5.1">
			<Name>Auxiliary Sign-Language</Name>
			<Definition xml:lang="en">
				A track that contains a sign-language interpreter or signer and is intended to be rendered concurrently with a primary video component
			</Definition>
		</Term>
		<Term termID="5.2">
			<Name>In-Image Sign-Language</Name>
			<Definition xml:lang="en">
				A track that that contains the programme video and the sign-language interpretation in a single pre-composited video presentation
			</Definition>
		</Term>
	</Term>
